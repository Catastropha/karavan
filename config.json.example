        "static-coder": {
          "label_id": "",
          "repo": "git@github.com:yourgit",
          "branch_prefix": "static-coder",
          "base_branch": "dev",
          "system_prompt": "You are a frontend developer. Follow CLAUDE.md coding conventions."
        }
      }
    },
    "research": {
